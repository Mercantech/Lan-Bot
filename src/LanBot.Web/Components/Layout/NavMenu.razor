@using Microsoft.AspNetCore.Components.Authorization

<div class="top-row">
    <div class="brand">
        <img src="/LanIcon.png" alt="Lan icon" class="brand-logo" />
        <div>
            <div class="brand-title">Netparty Datahouse</div>
            <div class="brand-sub">Gaming Tournament Hub</div>
        </div>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="menu-shell">
        <div class="menu-group">
            <div class="menu-label">Oversigt</div>
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-home-nav-menu" aria-hidden="true"></span>
                <span>Home</span>
            </NavLink>
            <NavLink class="nav-link" href="tournaments">
                <span class="bi bi-grid-nav-menu" aria-hidden="true"></span>
                <span>Tournaments</span>
            </NavLink>
            <NavLink class="nav-link" href="scoreboard">
                <span class="bi bi-trophy-fill-nav-menu" aria-hidden="true"></span>
                <span>Scoreboard</span>
            </NavLink>
        </div>

        <AuthorizeView Policy="AdminOnly">
            <Authorized>
                <div class="menu-group">
                    <div class="menu-label">Admin</div>
                    <NavLink class="nav-link" href="admin/tournaments/new">
                        <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span>
                        <span>Ny turnering</span>
                    </NavLink>
                    <NavLink class="nav-link" href="admin/matches/report">
                        <span class="bi bi-clipboard-nav-menu" aria-hidden="true"></span>
                        <span>Afgor match</span>
                    </NavLink>
                    <a class="nav-link" href="/logout">
                        <span class="bi bi-logout-nav-menu" aria-hidden="true"></span>
                        <span>Log ud</span>
                    </a>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="menu-group">
                    <div class="menu-label">Konto</div>
                    <a class="nav-link" href="/login">
                        <span class="bi bi-discord-nav-menu" aria-hidden="true"></span>
                        <span>Log ind med Discord</span>
                    </a>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

